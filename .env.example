# BuildScore AI Environment Configuration
#
# Copy this file to .env and fill in your actual values.
# IMPORTANT: Never commit .env to version control — it contains secrets.
#
# Get your Anthropic API key from:
# https://console.anthropic.com/account/keys

# Anthropic API key for Claude access.
# Required for all agent execution (Define, Research, Strategy, Critic, CEO).
# Format: sk-ant-...
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Optional: Port for Express API server (defaults to 3000)
# PORT=3000

# Optional: Node environment (defaults to development)
# NODE_ENV=development
