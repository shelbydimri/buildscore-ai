# BuildScore AI Environment Configuration
#
# Copy this file to .env and fill in your actual values.
# IMPORTANT: Never commit .env to version control — it contains secrets.
#
# Get your free Groq API key from:
# https://console.groq.com/keys

# Groq API key for LLM access.
# Required for all agent execution (Define, Research, Strategy, Critic, CEO).
# Free tier available at https://console.groq.com
# Format: gsk_...
GROQ_API_KEY=your-groq-key-here

# Optional: Port for Express API server (defaults to 3000)
# PORT=3000

# Optional: Node environment (defaults to development)
# NODE_ENV=development

# Optional: Enable TEST_MODE to mock the pipeline without API calls (testing only)
# TEST_MODE=false
